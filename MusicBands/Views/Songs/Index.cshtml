@model IEnumerable<MusicBands.Models.Song>

@{
    ViewData["Title"] = "Index";
}

<h1 >Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<div class="jumbotron" style="opacity:0.8">
    <table class="table">
        <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.SN_NAME)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.SN_YEAR)
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.SN_NAME)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.SN_YEAR)
                    </td>

                    <td>
                        <a asp-action="Edit" asp-route-id="@item.ID">Edit</a> |
                        <a asp-action="Details" asp-route-id="@item.ID">Details</a> |
                        <a asp-action="Delete" asp-route-id="@item.ID">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>