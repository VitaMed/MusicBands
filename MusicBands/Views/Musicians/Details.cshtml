@model MusicBands.Models.Musician

@{
    ViewData["Title"] = "Details";
}

<h1 style="color:white">Details</h1>

<div>
    <h4 style="color:white">Musician</h4>
    <hr />
    <div class="jumbotron" style="opacity:0.8">

        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.MS_NAME)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.MS_NAME)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.MS_YEAR)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.MS_YEAR)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.MS_SEX)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.MS_SEX)
            </dd>
            <dd class="col-sm-10">
                <table class="table">
                    <tr>
                        <th>Group</th>
                        <th>Producer</th>
                    </tr>
                    @foreach (var item in Model.MUSICIANS_IN_GROUPS)
                    {
                        <tr>
                            <td>
                                @Html.DisplayFor(modelItem => item.GROUP.GR_NAME)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.GROUP.PRODUCER.PR_NAME)
                            </td>
                        
                        </tr>
                    }

                </table>
          
        </dl>
    </div>
    </div>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.ID">Edit</a> |
        <a asp-action="Index">Back to List</a>
    </div>
