@model MusicBands.Models.ALBUMS

@{
    ViewData["Title"] = "Details";
}

<h1 style="color:white">Details</h1>

<div>
    <h4 style="color:white">Album</h4>
    <hr />
    <div class="jumbotron" style="opacity:0.9">
        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.AL_NAME)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.AL_NAME)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.AL_YEAR)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.AL_YEAR)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.SONGS)
            </dt>
            <dd class="col-sm-10">
                <table class="table">
                    <tr>
                        <th>Song</th>
                        <th>Year</th>
                    </tr>
                    @foreach (var item in Model.SONGS)
                    {
                        <tr>
                            <td>
                                @Html.DisplayFor(modelItem => item.SN_NAME)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.SN_YEAR)
                            </td>
                        </tr>
                    }
                </table>
            </dd>
        </dl>
    </div>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model.ID">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
