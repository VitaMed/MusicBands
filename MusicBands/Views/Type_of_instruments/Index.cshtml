@model IEnumerable<MusicBands.Models.Type_of_instruments>

@{
    ViewData["Title"] = "Index";
}
<style>
    body {
        background-position:top;
    }
</style>
<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<div class="jumbotron" style="opacity:0.8">

    <form asp-controller="Groups" asp-action="Index" method="post">
        @foreach (var item in Model)
        {
            <input type="checkbox" name="SelectedInstruments" value=@item.ID> @Html.DisplayFor(modelItem => item.IN_NAME) <br>
        }
        <input type="submit" value="Submit">
    </form>
</div>
<div class="jumbotron" style="opacity:0.8">
    <table class="table">
        <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.IN_NAME)
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.IN_NAME)
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.ID">Edit</a> |
                        <a asp-action="Delete" asp-route-id="@item.ID">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
