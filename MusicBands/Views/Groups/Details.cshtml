@model MusicBands.Models.Group

@{
    ViewData["Title"] = "Details";
}

<h1 style="color:white">Details</h1>

<div>
    <h4 style="color:white">Group</h4>
    <hr />
    <div class="jumbotron" style="opacity:0.9">
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.GR_NAME)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.GR_NAME)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.MUSICIANS_IN_GROUPS)
        </dt>
        <dd class="col-sm-10">
            <table class="table">
                <tr>
                    <th>Musician</th>
                    <th>Sex</th>
                    <th>Year</th>
                </tr>
                @foreach (var item in Model.MUSICIANS_IN_GROUPS)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.MUSICIAN.MS_NAME)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.MUSICIAN.MS_SEX)
                        </td> 
                        <td>
                            @Html.DisplayFor(modelItem => item.MUSICIAN.MS_YEAR)
                        </td>
                    </tr>
                }
            </table>
        </dd>
    </dl>
        </div>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model.ID">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
