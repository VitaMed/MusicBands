@model MusicBands.Models.Group

@{
    ViewData["Title"] = "Create";
}

<h1 style="color:white">Create</h1>

<h4 style="color:white">Group</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="GR_NAME" class="control-label" style="color:white"></label>
                <input asp-for="GR_NAME" class="form-control" />
                <span asp-validation-for="GR_NAME" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PR_ID" class="control-label" style="color:white"></label>
                <select asp-for="PR_ID" class="form-control">
                    @foreach (Producer producer in (List<Producer>)ViewData["Producers"])
                    {
                        <option value=@producer.ID>@producer.PR_NAME</option>
                    }
                </select>
                <span asp-validation-for="PR_ID" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
